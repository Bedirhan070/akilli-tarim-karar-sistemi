<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Akıllı Tarım Sistemi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --sidebar-bg: #1a3c2e;
            --sidebar-hover: #2d5a42;
            --sidebar-active: #4caf50;
            --accent: #4caf50;
            --accent-dark: #388e3c;
        }

        body {
            background: #f0f4f0;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Sidebar */
        #sidebar {
            width: 250px;
            min-height: 100vh;
            background: var(--sidebar-bg);
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1000;
            transition: width 0.3s;
            display: flex;
            flex-direction: column;
        }

        .sidebar-brand {
            padding: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            color: white;
            font-weight: bold;
            font-size: 1.1rem;
        }

        .sidebar-brand i {
            color: var(--accent);
            margin-right: 8px;
        }

        .sidebar-nav {
            flex: 1;
            padding: 15px 0;
        }

        .nav-section-title {
            color: rgba(255,255,255,0.4);
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 10px 20px 5px;
        }

        .sidebar-nav .nav-link {
            color: rgba(255,255,255,0.75);
            padding: 10px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-radius: 0;
            transition: all 0.2s;
            font-size: 0.9rem;
        }

        .sidebar-nav .nav-link:hover {
            background: var(--sidebar-hover);
            color: white;
        }

        .sidebar-nav .nav-link.active {
            background: var(--accent);
            color: white;
        }

        .sidebar-nav .nav-link i {
            width: 18px;
            text-align: center;
        }

        .sidebar-footer {
            padding: 15px 20px;
            border-top: 1px solid rgba(255,255,255,0.1);
        }

        .sidebar-footer .nav-link {
            color: rgba(255,255,255,0.6);
            padding: 8px 0;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.85rem;
        }

        .sidebar-footer .nav-link:hover {
            color: white;
        }

        /* Main content */
        #main-content {
            margin-left: 250px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Topbar */
        #topbar {
            background: white;
            padding: 12px 25px;
            border-bottom: 1px solid #e0e0e0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 999;
        }

        #topbar .page-title {
            font-weight: 600;
            color: #333;
            font-size: 1.1rem;
        }

        .user-badge {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-avatar {
            width: 35px;
            height: 35px;
            background: var(--accent);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
            font-size: 0.85rem;
        }

        .user-name {
            font-size: 0.9rem;
            font-weight: 500;
            color: #444;
        }

        /* Content area */
        .content-area {
            padding: 25px;
            flex: 1;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            #sidebar { width: 0; overflow: hidden; }
            #main-content { margin-left: 0; }
            #sidebar.open { width: 250px; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- Sidebar -->
    <div id="sidebar">
        <div class="sidebar-brand">
            <i class="fas fa-leaf"></i> Akıllı Tarım
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-title">Genel</div>
            <a href="/Home/Dashboard" class="nav-link @(ViewData["ActivePage"]?.ToString() == "dashboard" ? "active" : "")">
                <i class="fas fa-chart-line"></i> Dashboard
            </a>
            <a href="/Lokasyon" class="nav-link @(ViewData["ActivePage"]?.ToString() == "lokasyon" ? "active" : "")">
                <i class="fas fa-map-marker-alt"></i> Tarlalarım
            </a>

            <div class="nav-section-title">Analiz</div>
            <a href="/Analiz/AnlikRisk" class="nav-link @(ViewData["ActivePage"]?.ToString() == "anlik" ? "active" : "")">
                <i class="fas fa-bolt"></i> Anlık Risk Analizi
            </a>
            <a href="/Analiz/GelecekTahmini" class="nav-link @(ViewData["ActivePage"]?.ToString() == "tahmin" ? "active" : "")">
                <i class="fas fa-clock"></i> Gelecek Tahmini
            </a>
            <a href="/Analiz/HavaDurumu" class="nav-link @(ViewData["ActivePage"]?.ToString() == "hava" ? "active" : "")">
                <i class="fas fa-cloud-sun"></i> Hava Durumu
            </a>

            <div class="nav-section-title">Geçmiş</div>
            <a href="/Oneri" class="nav-link @(ViewData["ActivePage"]?.ToString() == "oneri" ? "active" : "")">
                <i class="fas fa-history"></i> Öneri Geçmişi
            </a>
        </nav>

        <div class="sidebar-footer">
            <a href="#" id="btnCikis" class="nav-link">
                <i class="fas fa-sign-out-alt"></i> Çıkış Yap
            </a>
        </div>
    </div>

    <!-- Main Content -->
    <div id="main-content">
        <!-- Topbar -->
        <div id="topbar">
            <span class="page-title">@(ViewData["Title"] ?? "Dashboard")</span>
            <div class="user-badge">
                <div class="user-avatar" id="userInitial">?</div>
                <span class="user-name" id="userName">Yükleniyor...</span>
            </div>
        </div>

        <!-- Content -->
        <div class="content-area">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Token kontrolü
        const token = localStorage.getItem('token');
        if (!token) {
            window.location.href = '/Home/Login';
        }

        // JWT'den kullanıcı adını çek
        function parseJwt(token) {
            try {
                return JSON.parse(atob(token.split('.')[1]));
            } catch (e) {
                return null;
            }
        }

        const payload = parseJwt(token);
        if (payload) {
            const ad = payload['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name'] || 'Kullanıcı';
            document.getElementById('userName').textContent = ad;
            document.getElementById('userInitial').textContent = ad.charAt(0).toUpperCase();
        }

        document.getElementById('btnCikis').addEventListener('click', (e) => {
            e.preventDefault();
            localStorage.removeItem('token');
            window.location.href = '/Home/Login';
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
