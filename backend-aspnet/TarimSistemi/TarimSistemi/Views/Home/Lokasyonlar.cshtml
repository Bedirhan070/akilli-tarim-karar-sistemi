@{
    ViewData["Title"] = "Tarlalarım";
    ViewData["ActivePage"] = "lokasyon";
}

@section Styles {
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
    /* Harita marker stilleri */
    .il-icon { background: transparent; border: none; }
    .il-badge {
        display: inline-block;
        background: #1a3c2e;
        color: #fff;
        padding: 4px 11px;
        border-radius: 14px;
        font-size: 0.74rem;
        font-weight: 700;
        white-space: nowrap;
        cursor: pointer;
        box-shadow: 0 2px 6px rgba(0,0,0,0.4);
        border: 2px solid rgba(255,255,255,0.6);
        transform: translate(-50%, -50%);
        transition: background 0.15s, transform 0.1s;
        user-select: none;
        pointer-events: all;
    }
    .il-badge:hover { background: #4caf50; transform: translate(-50%,-50%) scale(1.1); }

    .ilce-icon { background: transparent; border: none; }
    .ilce-badge {
        display: inline-block;
        background: #fff;
        color: #2e7d32;
        padding: 3px 9px;
        border-radius: 12px;
        font-size: 0.72rem;
        font-weight: 700;
        white-space: nowrap;
        cursor: pointer;
        box-shadow: 0 1px 5px rgba(0,0,0,0.25);
        border: 2px solid #4caf50;
        transform: translate(-50%, -50%);
        transition: all 0.15s;
        user-select: none;
        pointer-events: all;
    }
    .ilce-badge:hover  { background: #4caf50; color: #fff; transform: translate(-50%,-50%) scale(1.1); }
    .ilce-badge.active { background: #e65100; color: #fff; border-color: #e65100; }

    /* Sayfa düzeni */
    #harita { height: 560px; }

    .map-card {
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        overflow: hidden;
    }
    .map-header {
        background: #f9fafb;
        border-bottom: 1px solid #eee;
        padding: 9px 16px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.84rem;
        color: #555;
    }
    .map-header strong { color: #2e7d32; }

    .panel-card {
        background: #fff;
        border-radius: 12px;
        padding: 18px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    }
    .konum-empty {
        background: #f8f8f8;
        border: 2px dashed #ddd;
        border-radius: 10px;
        padding: 14px;
        text-align: center;
        color: #bbb;
        font-size: 0.82rem;
    }
    .konum-filled {
        background: #e8f5e9;
        border-radius: 10px;
        padding: 11px 14px;
        font-size: 0.84rem;
        color: #2e7d32;
        font-weight: 600;
    }

    .tarla-item {
        background: #fff;
        border-radius: 10px;
        padding: 12px 14px;
        margin-bottom: 9px;
        box-shadow: 0 1px 5px rgba(0,0,0,0.07);
        position: relative;
    }
    .tarla-item-name { font-weight: 700; font-size: 0.88rem; color: #222; }
    .tarla-item-info { font-size: 0.77rem; color: #999; margin-top: 3px; }
    .btn-sil {
        position: absolute; top: 10px; right: 10px;
        background: none; border: none; color: #ddd;
        cursor: pointer; font-size: 0.85rem;
        transition: color 0.2s; padding: 2px 5px;
    }
    .btn-sil:hover { color: #f44336; }

    .form-control, .form-select {
        border-radius: 8px;
        border: 1.5px solid #ddd;
        font-size: 0.88rem;
    }
    .form-control:focus {
        border-color: #4caf50;
        box-shadow: 0 0 0 3px rgba(76,175,80,0.15);
    }

    /* Yükleniyor örtüsü */
    #loadingOverlay {
        position: absolute; inset: 0;
        background: rgba(255,255,255,0.72);
        display: none;
        align-items: center;
        justify-content: center;
        border-radius: 0 0 12px 12px;
        z-index: 500;
    }
</style>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h5 class="mb-1" style="font-weight:700;color:#2e7d32;">Tarlalarım</h5>
        <small class="text-muted">Haritadan il → ilçe seçerek tarla konumu belirleyin</small>
    </div>
</div>

<div class="row g-3">

    <!-- Sol: Harita -->
    <div class="col-lg-8">
        <div class="map-card">
            <div class="map-header">
                <i class="fas fa-map-marked-alt text-success"></i>
                <span id="breadcrumb">Türkiye — Bir il seçin</span>
                <button id="btnGeri" class="btn btn-sm btn-light ms-auto d-none"
                        style="border-radius:7px;font-size:0.78rem;padding:3px 12px;">
                    <i class="fas fa-arrow-left me-1"></i>Geri
                </button>
            </div>
            <div style="position:relative;">
                <div id="harita"></div>
                <div id="loadingOverlay" style="display:none;">
                    <div class="text-center">
                        <div class="spinner-border text-success" style="width:1.5rem;height:1.5rem;"></div>
                        <div style="font-size:0.8rem;color:#555;margin-top:6px;">Konum aranıyor...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sağ: Form + Liste -->
    <div class="col-lg-4 d-flex flex-column gap-3">

        <!-- Tarla ekleme formu -->
        <div class="panel-card">
            <div class="fw-bold mb-3" style="font-size:0.93rem;color:#2e7d32;">
                <i class="fas fa-plus-circle me-1"></i>Yeni Tarla
            </div>

            <div id="konumEmpty" class="konum-empty mb-3">
                <i class="fas fa-hand-pointer d-block mb-1" style="font-size:1.4rem;"></i>
                Haritadan önce ili,<br>sonra ilçeyi seçin
            </div>
            <div id="konumFilled" class="konum-filled mb-3 d-none">
                <i class="fas fa-map-marker-alt me-1"></i>
                <span id="konumText">—</span>
            </div>

            <div class="mb-3">
                <label class="form-label" style="font-size:0.81rem;font-weight:600;color:#555;">
                    Tarla Adı <span class="text-muted fw-normal">(opsiyonel)</span>
                </label>
                <input type="text" class="form-control" id="fIsim" placeholder="Örn: Kuzey Tarla" />
            </div>

            <div id="formError" class="alert alert-danger d-none py-2 mb-2" style="font-size:0.81rem;border-radius:8px;"></div>

            <button id="btnKaydet" class="btn w-100 text-white fw-bold"
                    style="background:#4caf50;border-radius:8px;" disabled>
                <i class="fas fa-save me-1"></i>Tarla Olarak Kaydet
            </button>

            <input type="hidden" id="fIl" />
            <input type="hidden" id="fIlce" />
            <input type="hidden" id="fEnlem" />
            <input type="hidden" id="fBoylam" />
        </div>

        <!-- Kayıtlı tarlalar -->
        <div>
            <div class="d-flex align-items-center mb-2">
                <span class="fw-bold" style="font-size:0.84rem;color:#555;">
                    <i class="fas fa-seedling me-1 text-success"></i>Kayıtlı Tarlalar
                </span>
                <span id="tarlaCount" class="badge ms-2"
                      style="background:#e8f5e9;color:#2e7d32;font-size:0.72rem;"></span>
            </div>
            <div id="tarlaListesi">
                <div class="text-center text-muted py-3" style="font-size:0.84rem;">
                    <i class="fas fa-spinner fa-spin me-1"></i>Yükleniyor...
                </div>
            </div>
        </div>

    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

