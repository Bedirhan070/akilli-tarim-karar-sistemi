@{
    ViewData["Title"] = "Öneri Geçmişi";
    ViewData["ActivePage"] = "oneri";
}

<style>
    .gecmis-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        overflow: hidden;
    }
    .gecmis-card table { margin: 0; }
    .risk-pill {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    .risk-pill.kritik  { background: #ffebee; color: #c62828; }
    .risk-pill.uyari,
    .risk-pill.uyarı   { background: #fff8e1; color: #e65100; }
    .risk-pill.guvenli { background: #e8f5e9; color: #2e7d32; }
    .risk-pill.bos     { background: #f5f5f5; color: #888; }
    .tavsiye-text {
        font-size: 0.85rem;
        color: #555;
        max-width: 400px;
    }
    .filter-bar {
        background: white;
        border-radius: 12px;
        padding: 15px 20px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        margin-bottom: 20px;
    }
    .score-bar {
        height: 6px;
        border-radius: 3px;
        background: #eee;
        width: 80px;
        display: inline-block;
        vertical-align: middle;
        margin-right: 6px;
    }
    .score-fill {
        height: 100%;
        border-radius: 3px;
    }
    th { font-size: 0.8rem; color: #888; font-weight: 600; white-space: nowrap; }
    td { vertical-align: middle; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-1" style="font-weight:700; color:#2e7d32;">Öneri Geçmişi</h5>
        <small class="text-muted">Geçmiş analizleriniz ve önerileriniz</small>
    </div>
    <span class="badge" style="background:#e8f5e9;color:#2e7d32;font-size:0.85rem;padding:7px 14px;border-radius:8px;" id="toplamSayi">
        Yükleniyor...
    </span>
</div>

<!-- Filtre -->
<div class="filter-bar d-flex align-items-center gap-3 flex-wrap">
    <div>
        <label class="form-label mb-1" style="font-size:0.8rem;">Risk Seviyesi</label>
        <select class="form-select form-select-sm" id="filterRisk" style="width:140px;border-radius:8px;">
            <option value="">Tümü</option>
            <option value="Kritik">Kritik</option>
            <option value="Uyarı">Uyarı</option>
            <option value="Güvenli">Güvenli</option>
        </select>
    </div>
    <div>
        <label class="form-label mb-1" style="font-size:0.8rem;">Başlangıç</label>
        <input type="date" class="form-control form-control-sm" id="filterBaslangic" style="border-radius:8px;" />
    </div>
    <div>
        <label class="form-label mb-1" style="font-size:0.8rem;">Bitiş</label>
        <input type="date" class="form-control form-control-sm" id="filterBitis" style="border-radius:8px;" />
    </div>
    <div class="mt-3">
        <button class="btn btn-sm text-white" id="btnFiltrele"
                style="background:#4caf50;border-radius:8px;padding:6px 16px;">
            <i class="fas fa-filter me-1"></i>Filtrele
        </button>
        <button class="btn btn-sm btn-light ms-1" id="btnTemizle" style="border-radius:8px;">Temizle</button>
    </div>
</div>

<!-- Tablo -->
<div class="gecmis-card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead style="background:#f9fafb;">
                <tr>
                    <th class="ps-4">TARİH</th>
                    <th>LOKASYON</th>
                    <th>RİSK SEVİYESİ</th>
                    <th>RİSK SKORU</th>
                    <th>TAVSİYE</th>
                </tr>
            </thead>
            <tbody id="oneriBody">
                <tr><td colspan="5" class="text-center text-muted py-4">
                    <i class="fas fa-spinner fa-spin me-2"></i>Yükleniyor...
                </td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    const headers = { 'Authorization': 'Bearer ' + localStorage.getItem('token') };
    let tumOneriler = [];

    async function loadOneriler() {
        try {
            const res  = await fetch('/api/Oneri', { headers });
            tumOneriler = await res.json();
            renderTablo(tumOneriler);
        } catch {
            document.getElementById('oneriBody').innerHTML =
                '<tr><td colspan="5" class="text-center text-muted py-4">Veriler yüklenemedi</td></tr>';
        }
    }

    function renderTablo(data) {
        document.getElementById('toplamSayi').textContent = data.length + ' öneri';
        const tbody = document.getElementById('oneriBody');

        if (data.length === 0) {
            tbody.innerHTML = `<tr><td colspan="5" class="text-center text-muted py-5">
                <i class="fas fa-inbox fa-2x mb-2 d-block" style="opacity:0.2"></i>
                Henüz öneri bulunmuyor
            </td></tr>`;
            return;
        }

        tbody.innerHTML = data.map(o => {
            const risk   = (o.riskSkoru ?? 0);
            const yuzde  = Math.round(risk * 100);
            const seviye = risk > 0.70 ? 'kritik' : risk > 0.40 ? 'uyari' : 'guvenli';
            const renk   = risk > 0.70 ? '#f44336' : risk > 0.40 ? '#ff9800' : '#4caf50';
            const etiket = o.riskTipi || (risk > 0.70 ? 'Kritik' : risk > 0.40 ? 'Uyarı' : 'Güvenli');
            const tarih  = new Date(o.olusturulmaZamani).toLocaleString('tr-TR', {
                day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit'
            });

            return `<tr>
                <td class="ps-4">
                    <span style="font-size:0.85rem;color:#555;">${tarih}</span>
                </td>
                <td>
                    <span style="font-size:0.85rem;">${o.lokasyonAdi || '-'}</span>
                </td>
                <td>
                    <span class="risk-pill ${seviye}">${etiket}</span>
                </td>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <div class="score-bar">
                            <div class="score-fill" style="width:${yuzde}%;background:${renk};"></div>
                        </div>
                        <span style="font-size:0.85rem;font-weight:600;color:${renk};">%${yuzde}</span>
                    </div>
                </td>
                <td>
                    <div class="tavsiye-text">${o.tavsiyeMetni || '-'}</div>
                </td>
            </tr>`;
        }).join('');
    }

    document.getElementById('btnFiltrele').addEventListener('click', () => {
        let filtred = [...tumOneriler];

        const risk = document.getElementById('filterRisk').value;
        if (risk) filtred = filtred.filter(o => o.riskTipi === risk);

        const bas = document.getElementById('filterBaslangic').value;
        if (bas) filtred = filtred.filter(o => new Date(o.olusturulmaZamani) >= new Date(bas));

        const bit = document.getElementById('filterBitis').value;
        if (bit) filtred = filtred.filter(o => new Date(o.olusturulmaZamani) <= new Date(bit + 'T23:59:59'));

        renderTablo(filtred);
    });

    document.getElementById('btnTemizle').addEventListener('click', () => {
        document.getElementById('filterRisk').value = '';
        document.getElementById('filterBaslangic').value = '';
        document.getElementById('filterBitis').value = '';
        renderTablo(tumOneriler);
    });

    loadOneriler();
</script>
}
