@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "dashboard";
}

<style>
    .dash-page {
        max-width: 1420px;
        margin: 0 auto;
    }

    .dash-hero {
        background: linear-gradient(125deg, #e8f5e9 0%, #fff 42%, #f0f7f1 100%);
        border: 1px solid #b2dfbc;
        border-radius: 18px;
        padding: 22px 26px;
        margin-bottom: 20px;
        box-shadow: 0 8px 32px rgba(26,60,46,0.08);
    }

    .dash-hero h1 {
        font-size: 1.45rem;
        font-weight: 800;
        color: #1b5e20;
        margin: 0 0 8px;
        letter-spacing: -0.03em;
    }

    .dash-hero-desc {
        margin: 0;
        color: #4a6352;
        font-size: 0.92rem;
        line-height: 1.5;
        max-width: 640px;
    }

    .dash-toolbar {
        background: #fff;
        border-radius: 16px;
        padding: 18px 20px;
        border: 1px solid rgba(26,60,46,0.1);
        box-shadow: 0 4px 22px rgba(20,40,30,0.06);
        margin-bottom: 20px;
    }

    .dash-toolbar-inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
    }

    .dash-toolbar-actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
    }

    @@media (max-width: 576px) {
        .dash-toolbar-actions {
            width: 100%;
        }
        .dash-toolbar-actions #lokasyonSecim {
            width: 100%;
            max-width: none;
        }
    }

    .dash-quick {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 14px;
        padding-top: 14px;
        border-top: 1px dashed rgba(76,175,80,0.35);
    }

    .dash-quick a {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 14px;
        border-radius: 10px;
        font-size: 0.82rem;
        font-weight: 700;
        color: var(--bs-success);
        background: #e8f5e9;
        border: 1px solid #c8e6c9;
        text-decoration: none;
        transition: background 0.2s, transform 0.15s;
    }

    .dash-quick a:hover {
        background: #c8e6c9;
        color: #1b5e20;
        transform: translateY(-1px);
    }

    .btn-tahmin-outline {
        border-radius: 10px;
        font-weight: 700;
        border: 2px solid #42a5f5;
        color: #1565c0;
        padding: 8px 16px;
    }

    .btn-tahmin-outline:hover {
        background: #e3f2fd;
        color: #0d47a1;
        border-color: #2196f3;
    }

    .dash-ozet {
        border-radius: 14px !important;
        border: 1px solid #c8e6c9 !important;
        background: linear-gradient(90deg, #fafdfb, #fff) !important;
    }

    .stat-card {
        background: white;
        border-radius: 14px;
        padding: 20px 22px;
        border: 1px solid rgba(76,175,80,0.14);
        box-shadow: 0 4px 16px rgba(20,40,30,0.05);
        display: flex;
        align-items: center;
        gap: 15px;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .stat-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 28px rgba(46,125,50,0.12);
    }

    .stat-icon {
        width: 50px;
        height: 50px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        color: white;
        flex-shrink: 0;
    }

    .stat-icon.green  { background: #4caf50; }
    .stat-icon.blue   { background: #2196f3; }
    .stat-icon.orange { background: #ff9800; }
    .stat-icon.purple { background: #9c27b0; }

    .stat-label {
        font-size: 0.78rem;
        color: #888;
        margin-bottom: 3px;
    }

    .stat-value {
        font-size: 1.4rem;
        font-weight: 700;
        color: #222;
        line-height: 1;
    }

    .risk-card {
        background: white;
        border-radius: 16px;
        padding: 24px;
        border: 1px solid rgba(0,0,0,0.06);
        box-shadow: 0 6px 22px rgba(20,40,30,0.06);
    }

    .risk-badge {
        border-radius: 10px;
        padding: 20px;
        text-align: center;
        color: white;
    }

    .risk-badge.guvenlı  { background: linear-gradient(135deg, #43a047, #66bb6a); }
    .risk-badge.uyarı    { background: linear-gradient(135deg, #fb8c00, #ffa726); }
    .risk-badge.kritik   { background: linear-gradient(135deg, #e53935, #ef5350); }
    .risk-badge.beklıyor { background: linear-gradient(135deg, #78909c, #90a4ae); }

    .risk-score {
        font-size: 3rem;
        font-weight: 800;
        line-height: 1;
    }

    .risk-label {
        font-size: 1rem;
        opacity: 0.9;
        margin-top: 5px;
    }

    .info-card {
        background: white;
        border-radius: 16px;
        padding: 20px 22px;
        border: 1px solid rgba(0,0,0,0.06);
        box-shadow: 0 6px 22px rgba(20,40,30,0.06);
        height: 100%;
    }

    .info-card h6 {
        font-weight: 800;
        color: #2e4a38;
        border-bottom: 2px solid #e8f5e9;
        padding-bottom: 12px;
        margin-bottom: 16px;
        font-size: 0.95rem;
    }

    .weather-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #f5f5f5;
        font-size: 0.88rem;
    }

    .weather-item:last-child { border-bottom: none; }

    .weather-item .label { color: #888; }
    .weather-item .val   { font-weight: 600; color: #333; }

    .oneri-item {
        background: #f9f9f9;
        border-radius: 8px;
        padding: 12px 15px;
        margin-bottom: 10px;
        border-left: 4px solid #4caf50;
        font-size: 0.87rem;
        color: #444;
    }

    .oneri-item.uyarı  { border-left-color: #ff9800; }
    .oneri-item.kritik { border-left-color: #f44336; }

    .oneri-tarih {
        font-size: 0.75rem;
        color: #aaa;
        margin-top: 4px;
    }

    .section-title {
        font-size: 1rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 15px;
    }

    .btn-analiz {
        background: linear-gradient(135deg, #43a047, #66bb6a);
        border: none;
        color: white;
        padding: 10px 22px;
        border-radius: 10px;
        font-weight: 800;
        letter-spacing: 0.02em;
        transition: all 0.2s;
        box-shadow: 0 4px 14px rgba(67,160,71,0.35);
    }

    .btn-analiz:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(76,175,80,0.45);
        color: white;
    }

    .placeholder-chart {
        background: #f5f5f5;
        border-radius: 8px;
        min-height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #bbb;
        font-size: 0.85rem;
        flex-direction: column;
        gap: 8px;
        padding: 16px;
    }

    .tahmin-risk-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 6px;
        font-size: 0.78rem;
    }
    .tahmin-risk-row .lbl {
        width: 88px;
        flex-shrink: 0;
        color: #666;
        font-weight: 600;
    }
    .tahmin-risk-bar-wrap {
        flex: 1;
        height: 10px;
        background: #eee;
        border-radius: 5px;
        overflow: hidden;
    }
    .tahmin-risk-bar {
        height: 100%;
        border-radius: 5px;
        transition: width 0.35s ease;
    }
    .tahmin-table th { font-size: 0.72rem; color: #888; }
    .tahmin-table td { font-size: 0.8rem; vertical-align: middle; }
    .pill-risk { font-size: 0.68rem; padding: 2px 8px; border-radius: 10px; font-weight: 600; }
    .pill-risk.dusuk { background: #e8f5e9; color: #2e7d32; }
    .pill-risk.uyari { background: #fff8e1; color: #e65100; }
    .pill-risk.kritik { background: #ffebee; color: #c62828; }

    #lokasyonSecim {
        border-radius: 10px;
        border: 2px solid #c8e6c9;
        font-size: 0.9rem;
        font-weight: 600;
        min-width: 200px;
        max-width: 280px;
    }

    /* Bölüm hedefleri: üst çubuk altında kalsın */
    .dash-section-anchor {
        scroll-margin-top: 80px;
    }

    .dash-section-head {
        background: linear-gradient(135deg, #e8f5e9 0%, #fff 100%);
        border: 1px solid #c8e6c9;
        border-radius: 14px;
        padding: 16px 20px;
        margin-bottom: 14px;
        box-shadow: 0 2px 12px rgba(46,125,50,0.06);
    }

    .dash-section-head.tahmin-head {
        background: linear-gradient(135deg, #e3f2fd 0%, #fff 100%);
        border-color: #bbdefb;
    }

    .dash-section-head .dash-ikon {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        margin-right: 12px;
        vertical-align: middle;
    }

    .dash-section-head .dash-ikon.anlik { background: #fff8e1; color: #f57c00; }
    .dash-section-head .dash-ikon.tahmin { background: #e3f2fd; color: #1565c0; }

    .dash-section-head .baslik-metin {
        display: inline-block;
        vertical-align: middle;
        max-width: calc(100% - 58px);
    }

    .dash-section-head h2 {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1b5e20;
        margin: 0;
    }

    .dash-section-head.tahmin-head h2 { color: #0d47a1; }

    .dash-section-head p {
        margin: 4px 0 0;
        font-size: 0.84rem;
        color: #666;
        line-height: 1.4;
    }

    .analiz-merkez-kart {
        display: block;
        border-radius: 16px;
        padding: 20px 22px;
        text-decoration: none;
        color: inherit;
        border: 2px solid transparent;
        box-shadow: 0 6px 22px rgba(20,40,30,0.07);
        transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
        height: 100%;
        background: #fff;
    }

    .analiz-merkez-kart:hover {
        transform: translateY(-4px);
        box-shadow: 0 14px 36px rgba(46,125,50,0.14);
        color: inherit;
    }

    .analiz-merkez-kart--anlik { border-color: #a5d6a7; }
    .analiz-merkez-kart--anlik:hover { border-color: #4caf50; }

    .analiz-merkez-kart--tahmin { border-color: #90caf9; }
    .analiz-merkez-kart--tahmin:hover { border-color: #2196f3; }

    .analiz-merkez-kart .am-ikon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
        margin-bottom: 12px;
    }

    .analiz-merkez-kart--anlik .am-ikon { background: #e8f5e9; color: #2e7d32; }
    .analiz-merkez-kart--tahmin .am-ikon { background: #e3f2fd; color: #1565c0; }

    .analiz-merkez-kart h3 {
        font-size: 1.05rem;
        font-weight: 700;
        color: #222;
        margin: 0 0 6px;
    }

    .analiz-merkez-kart p {
        font-size: 0.86rem;
        color: #666;
        margin: 0;
        line-height: 1.45;
    }

    .analiz-merkez-kart .am-ok {
        margin-top: 12px;
        font-size: 0.8rem;
        font-weight: 600;
        color: #2e7d32;
    }

    .analiz-merkez-kart--tahmin .am-ok { color: #1565c0; }

    @@keyframes dashSectionFlash {
        0%, 100% { box-shadow: 0 0 0 0 rgba(76,175,80,0); }
        40% { box-shadow: 0 0 0 4px rgba(76,175,80,0.35); }
    }

    .dash-section-anchor.dash-flash .dash-section-head {
        animation: dashSectionFlash 1.1s ease;
    }
</style>

<div class="dash-page">

<div class="dash-hero">
    <h1>Karar destek paneli</h1>
    <p class="dash-hero-desc">Tarlanızı seçin, bugünkü riski ve haftalık hava özetini tek ekranda görün. Aşağıdaki yeşil ve mavi bölümler menüdeki <strong>Bugünkü risk</strong> ve <strong>7 günlük tahmin</strong> ile aynı yerlere kaydırır.</p>
    <small class="text-dark fw-semibold d-block mt-2" id="seciliTarlaBaslik" style="font-size:0.86rem;"></small>
</div>

<div class="dash-toolbar">
    <div class="dash-toolbar-inner">
        <label for="lokasyonSecim" class="small text-muted fw-semibold mb-0 d-block d-md-inline me-md-2">Tarla</label>
        <div class="dash-toolbar-actions flex-grow-1 justify-content-md-end">
            <select class="form-select form-select-sm" id="lokasyonSecim">
                <option value="">-- Tarla seçin --</option>
            </select>
            <button type="button" class="btn btn-analiz btn-sm" id="btnAnalize">
                <i class="fas fa-play me-1"></i> Analiz et
            </button>
            <button type="button" class="btn btn-sm btn-tahmin-outline" id="btnTahminYukle" title="Hava API 7 günlük tahmin">
                <i class="fas fa-calendar-week me-1"></i> 7 gün tahmin
            </button>
        </div>
    </div>
    <div class="dash-quick">
        <a href="/Home/Lokasyonlar"><i class="fas fa-map-marked-alt"></i>Tarlalarım</a>
        <a href="/Home/OneriGecmisi"><i class="fas fa-history"></i>Öneri geçmişi</a>
    </div>
</div>

<div id="tarlaOzeti" class="alert alert-light border dash-ozet mb-4 d-none py-2 px-3" style="font-size:0.86rem;">
    <div class="d-flex flex-wrap align-items-start gap-2 justify-content-between">
        <div>
            <span class="text-muted me-1">Seçili ürün:</span>
            <strong id="ozetUrunAd" class="text-dark">—</strong>
            <div class="text-muted mt-1" id="ozetUrunDetay" style="font-size:0.8rem;max-width:520px;"></div>
        </div>
        <span id="ozetUrunUyari" class="badge bg-warning text-dark d-none">Ürün atanmadı</span>
    </div>
</div>

<!-- Çiftçi: ne yapacağını seçsin -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="small text-muted fw-semibold text-uppercase mb-2" style="letter-spacing:0.04em;">Ne yapmak istiyorsunuz?</div>
    </div>
    <div class="col-md-6">
        <a href="#analiz-anlik" class="analiz-merkez-kart analiz-merkez-kart--anlik" id="kartGitAnlik" aria-label="Bugünkü risk bölümüne git">
            <div class="am-ikon"><i class="fas fa-bolt"></i></div>
            <h3>Bugünkü riski görmek istiyorum</h3>
            <p>Üstten tarlanızı seçin, <strong>Analiz Et</strong>’e basın. Bugünkü hava ile tarladaki ürününüz karşılaştırılır; risk yüzdesi, hava özeti ve size özel kısa öneri çıkar.</p>
            <div class="am-ok"><i class="fas fa-arrow-down me-1"></i>Bu sayfada aşağıdaki yeşil bölüme git</div>
        </a>
    </div>
    <div class="col-md-6">
        <a href="#analiz-tahmin" class="analiz-merkez-kart analiz-merkez-kart--tahmin" id="kartGitTahmin" aria-label="Yedi günlük tahmin bölümüne git">
            <div class="am-ikon"><i class="fas fa-calendar-week"></i></div>
            <h3>Önümüzdeki günleri merak ediyorum</h3>
            <p>Tarla seçiliyken <strong>7 Gün Tahmin</strong>’e basın. Haftalık sıcaklık, yağış ve basit risk çubukları görünür; iş planı yapmanıza yardım eder.</p>
            <div class="am-ok"><i class="fas fa-arrow-down me-1"></i>Mavi bölüme git — tablo ve grafik</div>
        </a>
    </div>
</div>

<!-- Üst İstatistik Kartları -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="fas fa-map-marker-alt"></i></div>
            <div>
                <div class="stat-label">Kayıtlı Tarla</div>
                <div class="stat-value" id="statTarla">-</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-thermometer-half"></i></div>
            <div>
                <div class="stat-label">Sıcaklık</div>
                <div class="stat-value" id="statSicaklik">-</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="fas fa-tint"></i></div>
            <div>
                <div class="stat-label">Nem</div>
                <div class="stat-value" id="statNem">-</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon purple"><i class="fas fa-lightbulb"></i></div>
            <div>
                <div class="stat-label">Son Öneriler</div>
                <div class="stat-value" id="statOneri">-</div>
            </div>
        </div>
    </div>
</div>

<!-- 1 — Anlık analiz (tek kaydırma hedefi: başlık + kartlar) -->
<div id="analiz-anlik" class="dash-section-anchor">
    <div class="dash-section-head">
        <span class="dash-ikon anlik"><i class="fas fa-bolt"></i></span>
        <div class="baslik-metin">
            <h2>Bugünkü risk analizi</h2>
            <p>Tarla ve ürün seçili olmalı. Üstteki <strong>Analiz Et</strong> ile güncel verileri çekin; skor solda, hava ortada, öneri sağdadır.</p>
        </div>
    </div>
<div class="row g-3">

    <!-- Risk Kartı -->
    <div class="col-md-4">
        <div class="risk-card h-100">
            <div class="section-title"><i class="fas fa-shield-alt me-2 text-success"></i>Risk Durumu</div>
            <div class="risk-badge beklıyor mb-3" id="riskBadge">
                <div class="risk-score" id="riskScore">-</div>
                <div class="risk-label" id="riskLabel">Tarla seçin</div>
            </div>
            <div class="d-flex flex-column gap-2">
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted"><i class="fas fa-check-circle text-success me-1"></i>Anomali Durumu</small>
                    <span class="badge bg-secondary" id="anomaliBadge">Bekleniyor</span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted"><i class="fas fa-brain text-primary me-1"></i>Model</small>
                    <span class="badge bg-secondary" id="modelBadge">Kural tabanı</span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-muted"><i class="fas fa-clock text-warning me-1"></i>Son Güncelleme</small>
                    <span class="text-muted" style="font-size:0.8rem;" id="sonGuncelleme">-</span>
                </div>
            </div>
            <div class="mt-3 pt-3 border-top">
                <div class="small fw-bold text-secondary mb-2">
                    <i class="fas fa-list-ul me-1 text-success"></i>Anlık risk dökümü
                </div>
                <ul id="riskEtkenListesi" class="small mb-0 ps-3 text-muted" style="line-height:1.55;">
                    <li>Tarla seçip <strong>Analiz Et</strong> dediğinizde, hava ve ürün idealine göre risk etkenleri burada listelenir.</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Hava Durumu Kartı -->
    <div class="col-md-4">
        <div class="info-card">
            <h6><i class="fas fa-cloud-sun me-2 text-warning"></i>Hava Durumu</h6>
            <div id="havaContainer">
                <div class="weather-item">
                    <span class="label"><i class="fas fa-thermometer-half me-1"></i>Maks. Sıcaklık</span>
                    <span class="val" id="hwSicaklikMax">-</span>
                </div>
                <div class="weather-item">
                    <span class="label"><i class="fas fa-thermometer-quarter me-1"></i>Min. Sıcaklık</span>
                    <span class="val" id="hwSicaklikMin">-</span>
                </div>
                <div class="weather-item">
                    <span class="label"><i class="fas fa-tint me-1"></i>Nem</span>
                    <span class="val" id="hwNem">-</span>
                </div>
                <div class="weather-item">
                    <span class="label"><i class="fas fa-cloud-rain me-1"></i>Yağış</span>
                    <span class="val" id="hwYagis">-</span>
                </div>
                <div class="weather-item">
                    <span class="label"><i class="fas fa-wind me-1"></i>Rüzgar</span>
                    <span class="val" id="hwRuzgar">-</span>
                </div>
                <div class="weather-item">
                    <span class="label"><i class="fas fa-satellite-dish me-1"></i>Kaynak</span>
                    <span class="val" id="hwKaynak">-</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Öneri Kartı -->
    <div class="col-md-4">
        <div class="info-card">
            <h6><i class="fas fa-seedling me-2 text-success"></i>Aksiyon Önerisi</h6>
            <div id="oneriContainer">
                <div class="text-center text-muted py-3">
                    <i class="fas fa-info-circle fa-2x mb-2 d-block" style="opacity:0.3"></i>
                    Analiz yapmak için tarla seçin ve "Analiz Et" butonuna basın
                </div>
            </div>
        </div>
    </div>

</div>
</div>

<!-- 2 — Haftalık tahmin -->
<div id="analiz-tahmin" class="dash-section-anchor mt-2">
    <div class="dash-section-head tahmin-head">
        <span class="dash-ikon tahmin"><i class="fas fa-cloud-sun"></i></span>
        <div class="baslik-metin">
            <h2>Haftalık hava ve risk özeti</h2>
            <p>Meteoroloji kaynaklı 7 günlük tablo ve renkli risk çubukları. İleride yapay zekâ (LSTM) ile bu grafik daha da keskinleşecek.</p>
        </div>
    </div>
<div class="row g-3">

    <!-- 7 Günlük Tahmin -->
    <div class="col-md-8">
        <div class="info-card">
            <h6 class="d-flex align-items-center flex-wrap gap-2">
                <span><i class="fas fa-chart-line me-2 text-primary"></i>Gelecek tahmini (7 gün)</span>
                <span class="badge bg-light text-secondary border" style="font-size:0.62rem;">Open-Meteo</span>
                <span class="badge border text-muted bg-white" style="font-size:0.62rem;">LSTM → sonra</span>
            </h6>
            <p class="small text-muted mb-2" id="tahminAciklama" style="display:none;"></p>
            <div id="tahminPlaceholder" class="placeholder-chart mb-0">
                <i class="fas fa-cloud-sun fa-2x" style="opacity:0.3"></i>
                <span>Tarla seçip <strong>7 Gün Tahmin</strong> veya <strong>Analiz Et</strong> ile doldurun</span>
                <span class="small text-center" style="max-width:340px;">Günlük sütunlarda hava tahmini + ürününüze göre özet risk skoru gösterilir; LSTM entegrasyonu geldiğinde eğri burada güçlenir.</span>
            </div>
            <div id="tahminIcerik" class="d-none">
                <div class="mb-3" id="tahminRiskChart" aria-label="Günlük risk çubukları"></div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover tahmin-table mb-0">
                        <thead>
                            <tr>
                                <th>Gün</th>
                                <th>Tarih</th>
                                <th>Max/Min °C</th>
                                <th>Nem</th>
                                <th>Yağış</th>
                                <th>Risk</th>
                            </tr>
                        </thead>
                        <tbody id="tahminTabloBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Son Öneriler -->
    <div class="col-md-4">
        <div class="info-card">
            <h6><i class="fas fa-history me-2 text-secondary"></i>Son Öneriler</h6>
            <div id="sonOnerilerContainer">
                <div class="text-center text-muted py-3" style="font-size:0.85rem;">
                    Henüz öneri bulunmuyor
                </div>
            </div>
            <a href="/Home/OneriGecmisi" class="btn btn-sm btn-outline-success w-100 mt-2">Tüm Geçmişi Gör</a>
        </div>
    </div>

</div>
</div>

</div>

@section Scripts {
<script>
    const authHeaders = {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + localStorage.getItem('token')
    };

    let lokasyonCache = [];

    const riskEtkenVarsayilanHtml = `<li>Tarla seçip <strong>Analiz Et</strong> dediğinizde, hava ve ürün idealine göre risk etkenleri burada listelenir.</li>`;

    function guncelleSeciliTarlaBaslik() {
        const lokId = document.getElementById('lokasyonSecim').value;
        const el = document.getElementById('seciliTarlaBaslik');
        if (!lokId) {
            el.textContent = '';
            return;
        }
        const lok = lokasyonCache.find(x => String(x.lokasyonId) === String(lokId));
        if (!lok) return;
        const ad = lok.isim || `${lok.sehir}${lok.ilce ? ' / ' + lok.ilce : ''}`;
        el.textContent = 'Seçili tarla: ' + ad;
    }

    function riskEtkenleriniGoster(liste) {
        const ul = document.getElementById('riskEtkenListesi');
        if (!liste || !liste.length) {
            ul.innerHTML = riskEtkenVarsayilanHtml;
            return;
        }
        ul.innerHTML = liste.map(x => `<li>${String(x).replace(/</g, '&lt;')}</li>`).join('');
    }

    function tahminArayuzuSifirla() {
        document.getElementById('tahminIcerik').classList.add('d-none');
        document.getElementById('tahminPlaceholder').classList.remove('d-none');
        document.getElementById('tahminAciklama').style.display = 'none';
        document.getElementById('tahminRiskChart').innerHTML = '';
        document.getElementById('tahminTabloBody').innerHTML = '';
    }

    function tahminVerisiniCiz(data) {
        const ph = document.getElementById('tahminPlaceholder');
        const ic = document.getElementById('tahminIcerik');
        const ack = document.getElementById('tahminAciklama');
        const chart = document.getElementById('tahminRiskChart');
        const tbody = document.getElementById('tahminTabloBody');

        if (!data.tahminler || !data.tahminler.length) {
            tahminArayuzuSifirla();
            return;
        }

        ph.classList.add('d-none');
        ic.classList.remove('d-none');
        if (data.aciklama) {
            ack.textContent = data.aciklama;
            ack.style.display = 'block';
        }

        chart.innerHTML = data.tahminler.map(t => {
            const pct = Math.min(100, Math.round((Number(t.riskSkoru) || 0) * 100));
            let cls = 'bg-success';
            if (t.riskOzeti === 'Kritik') cls = 'bg-danger';
            else if (t.riskOzeti === 'Uyarı') cls = 'bg-warning';
            const gun = t.gunAdi || '';
            return `<div class="tahmin-risk-row">
                <span class="lbl text-capitalize">${gun}</span>
                <div class="tahmin-risk-bar-wrap"><div class="tahmin-risk-bar ${cls}" style="width:${pct}%"></div></div>
                <span class="text-muted" style="min-width:36px;">%${pct}</span>
            </div>`;
        }).join('');

        tbody.innerHTML = data.tahminler.map(t => {
            const rs = Number(t.riskSkoru) || 0;
            let pill = 'dusuk';
            if (t.riskOzeti === 'Kritik') pill = 'kritik';
            else if (t.riskOzeti === 'Uyarı') pill = 'uyari';
            const maxmin = (t.sicaklikMax != null ? t.sicaklikMax : '—') + ' / ' + (t.sicaklikMin != null ? t.sicaklikMin : '—');
            return `<tr>
                <td class="text-capitalize">${t.gunAdi || ''}</td>
                <td>${t.tarih || ''}</td>
                <td>${maxmin}°C</td>
                <td>${t.nem != null ? '%' + t.nem : '—'}</td>
                <td>${t.yagis != null ? t.yagis + ' mm' : '—'}</td>
                <td><span class="pill-risk ${pill}">${t.riskOzeti || '—'} (${Math.round(rs * 100)}%)</span></td>
            </tr>`;
        }).join('');
    }

    async function tahminYukle(sessiz) {
        const lokId = document.getElementById('lokasyonSecim').value;
        if (!lokId) {
            if (!sessiz) alert('Önce tarla seçin');
            return;
        }
        const btn = document.getElementById('btnTahminYukle');
        if (!sessiz) btn.disabled = true;
        try {
            const res = await fetch(`/api/Analiz/tahmin/${lokId}`, { method: 'POST', headers: authHeaders });
            const data = await res.json();
            if (!res.ok) {
                if (!sessiz) alert(data.message || 'Tahmin alınamadı');
                return;
            }
            tahminVerisiniCiz(data);
        } catch (e) {
            if (!sessiz) alert('Bağlantı hatası: ' + e.message);
        } finally {
            if (!sessiz) btn.disabled = false;
        }
    }

    function formatUrunOzeti(u) {
        if (!u) return '';
        const p = [];
        if (u.idealSicaklikMin != null && u.idealSicaklikMax != null)
            p.push(`İdeal sıcaklık ${u.idealSicaklikMin}–${u.idealSicaklikMax}°C`);
        if (u.idealNemMin != null && u.idealNemMax != null)
            p.push(`nem %${u.idealNemMin}–${u.idealNemMax}`);
        if (u.ekimAylari) p.push(`ekim ayları: ${u.ekimAylari}`);
        return p.length ? p.join(' · ') : (u.aciklama || '');
    }

    async function tarlaOzetiGuncelle() {
        const lokId = document.getElementById('lokasyonSecim').value;
        guncelleSeciliTarlaBaslik();
        const wrap = document.getElementById('tarlaOzeti');
        const adEl = document.getElementById('ozetUrunAd');
        const detEl = document.getElementById('ozetUrunDetay');
        const uyari = document.getElementById('ozetUrunUyari');
        if (!lokId) {
            wrap.classList.add('d-none');
            tahminArayuzuSifirla();
            riskEtkenleriniGoster(null);
            return;
        }
        wrap.classList.remove('d-none');
        const lok = lokasyonCache.find(x => String(x.lokasyonId) === String(lokId));
        if (!lok) return;
        uyari.classList.toggle('d-none', !!lok.urunId);
        if (!lok.urunId) {
            adEl.textContent = 'Atanmadı';
            detEl.textContent = 'Tarlalarım sayfasından bu tarlaya ürün seçin; analiz yalnızca ürün atandıktan sonra çalışır.';
            return;
        }
        adEl.textContent = lok.urunAdi || 'Ürün';
        detEl.textContent = 'Yükleniyor...';
        try {
            const res = await fetch(`/api/Urun/${lok.urunId}`, { headers: authHeaders });
            if (!res.ok) throw new Error();
            const u = await res.json();
            detEl.textContent = formatUrunOzeti(u);
        } catch {
            detEl.textContent = '';
        }
    }

    // Lokasyonları yükle
    async function loadLokasyonlar() {
        try {
            const res = await fetch('/api/Lokasyon', { headers: authHeaders });
            if (!res.ok) return;
            const data = await res.json();
            lokasyonCache = data;
            const sel = document.getElementById('lokasyonSecim');
            sel.querySelectorAll('option:not(:first-child)').forEach(o => o.remove());
            data.forEach(l => {
                const opt = document.createElement('option');
                opt.value = l.lokasyonId;
                opt.textContent = l.isim || `${l.sehir} / ${l.ilce || ''}`.trim();
                sel.appendChild(opt);
            });
            document.getElementById('statTarla').textContent = data.length;
            await tarlaOzetiGuncelle();
        } catch {}
    }

    document.getElementById('lokasyonSecim').addEventListener('change', () => { tarlaOzetiGuncelle(); });
    document.getElementById('btnTahminYukle').addEventListener('click', () => tahminYukle());

    function dashHashVurgula() {
        const h = (location.hash || '').replace(/^#/, '');
        document.querySelectorAll('.dash-section-anchor.dash-flash').forEach(function (e) {
            e.classList.remove('dash-flash');
        });
        if (!h) return;
        const el = document.getElementById(h);
        if (el && el.classList.contains('dash-section-anchor')) {
            el.classList.add('dash-flash');
            setTimeout(function () { el.classList.remove('dash-flash'); }, 1100);
        }
    }
    window.addEventListener('hashchange', dashHashVurgula);

    // Son önerileri yükle
    async function loadSonOneriler() {
        try {
            const res = await fetch('/api/Oneri/son', { headers: authHeaders });
            if (!res.ok) return;
            const data = await res.json();
            document.getElementById('statOneri').textContent = data.length;
            const container = document.getElementById('sonOnerilerContainer');
            if (data.length === 0) return;
            container.innerHTML = '';
            data.slice(0, 3).forEach(o => {
                const seviye = o.riskSkoru > 0.70 ? 'kritik' : o.riskSkoru > 0.40 ? 'uyarı' : '';
                const urunEt = o.urunAdi ? `<span class="badge bg-light text-dark border me-1" style="font-size:0.68rem;">${o.urunAdi}</span>` : '';
                container.innerHTML += `
                    <div class="oneri-item ${seviye}">
                        <div>${urunEt}${o.tavsiyeMetni || 'Öneri metni yok'}</div>
                        <div class="oneri-tarih">${new Date(o.olusturulmaZamani).toLocaleDateString('tr-TR')}</div>
                    </div>`;
            });
        } catch {}
    }

    // Analiz Et butonu
    document.getElementById('btnAnalize').addEventListener('click', async () => {
        const lokId = document.getElementById('lokasyonSecim').value;
        if (!lokId) {
            alert('Lütfen bir tarla seçin');
            return;
        }
        const lok = lokasyonCache.find(x => String(x.lokasyonId) === String(lokId));
        if (!lok || !lok.urunId) {
            alert('Bu tarla için ürün seçilmedi. Tarlalarım sayfasından ürün atayın.');
            return;
        }

        const btn = document.getElementById('btnAnalize');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Analiz ediliyor...';

        try {
            const res = await fetch(`/api/Analiz/anlik/${lokId}`, {
                method: 'POST',
                headers: authHeaders
            });
            const data = await res.json();

            if (!res.ok) {
                alert(data.message || 'Analiz sırasında hata oluştu');
                return;
            }

            // Risk badge güncelle
            const score = data.riskSkoru ?? 0;
            const badge = document.getElementById('riskBadge');
            badge.className = 'risk-badge mb-3';
            if (score > 0.70) {
                badge.classList.add('kritik');
                document.getElementById('riskLabel').textContent = 'KRİTİK RİSK';
            } else if (score > 0.40) {
                badge.classList.add('uyarı');
                document.getElementById('riskLabel').textContent = 'ORTA RİSK';
            } else {
                badge.classList.add('guvenlı');
                document.getElementById('riskLabel').textContent = 'GÜVENLİ';
            }
            document.getElementById('riskScore').textContent = (score * 100).toFixed(0) + '%';

            // Anomali badge
            const anomali = data.anomaliBulundu === true;
            document.getElementById('anomaliBadge').textContent = anomali ? 'Anomali Var' : 'Normal';
            document.getElementById('anomaliBadge').className = 'badge ' + (anomali ? 'bg-danger' : 'bg-success');

            document.getElementById('sonGuncelleme').textContent = new Date().toLocaleTimeString('tr-TR');

            riskEtkenleriniGoster(data.riskEtkenleri);

            // Hava durumu
            if (data.havaVerisi) {
                const hw = data.havaVerisi;
                document.getElementById('hwSicaklikMax').textContent = hw.sicaklikMax != null ? hw.sicaklikMax + '°C' : '-';
                document.getElementById('hwSicaklikMin').textContent = hw.sicaklikMin != null ? hw.sicaklikMin + '°C' : '-';
                document.getElementById('hwNem').textContent = hw.nem != null ? '%' + hw.nem : '-';
                document.getElementById('hwYagis').textContent = hw.yagis != null ? hw.yagis + ' mm' : '-';
                document.getElementById('hwRuzgar').textContent = hw.ruzgarHizi != null ? hw.ruzgarHizi + ' km/h' : '-';
                document.getElementById('hwKaynak').textContent = hw.apiKaynagi || '-';
                document.getElementById('statSicaklik').textContent = hw.sicaklikMax != null ? hw.sicaklikMax + '°C' : '-';
                document.getElementById('statNem').textContent = hw.nem != null ? '%' + hw.nem : '-';
            }

            // Öneri metni
            if (data.tavsiyeMetni) {
                const seviye = score > 0.70 ? 'kritik' : score > 0.40 ? 'uyarı' : '';
                const urunBas = data.urunAdi
                    ? `<div class="mb-2"><span class="badge bg-success" style="font-size:0.72rem;">${data.urunAdi}</span>`
                      + (data.urunOzeti ? `<div class="text-muted mt-1" style="font-size:0.78rem;">${data.urunOzeti}</div>` : '')
                      + `</div>` : '';
                document.getElementById('oneriContainer').innerHTML = urunBas + `
                    <div class="oneri-item ${seviye}">
                        <i class="fas fa-info-circle me-1"></i>
                        ${data.tavsiyeMetni}
                    </div>`;
            }

            await loadSonOneriler();
            await tahminYukle(true);

        } catch (e) {
            alert('Bağlantı hatası: ' + e.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-play me-1"></i> Analiz Et';
        }
    });

    // Sayfa yüklenince
    loadLokasyonlar();
    loadSonOneriler();
    setTimeout(dashHashVurgula, 450);
</script>
}
