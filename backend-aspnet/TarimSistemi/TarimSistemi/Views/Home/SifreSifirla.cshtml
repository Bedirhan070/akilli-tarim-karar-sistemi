@{
    Layout = null;
    ViewData["Title"] = "Şifre sıfırlama";
    var resetToken = ViewBag.ResetToken as string;
    var hasToken = !string.IsNullOrWhiteSpace(resetToken);
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Şifre sıfırlama - Akıllı Tarım</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            background: linear-gradient(135deg, #1a3c2e 0%, #2d5a42 50%, #4caf50 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .auth-card {
            background: white;
            border-radius: 16px;
            padding: 40px 36px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.25);
        }
        .auth-card h2 { font-size: 1.35rem; font-weight: 800; color: #1a3c2e; margin-bottom: 6px; }
        .auth-card .subtitle { color: #888; font-size: 0.88rem; margin-bottom: 22px; }
        .form-label { font-size: 0.85rem; font-weight: 600; color: #555; }
        .form-control { border-radius: 8px; border: 1.5px solid #ddd; padding: 10px 14px; }
        .form-control:focus { border-color: #4caf50; box-shadow: 0 0 0 3px rgba(76,175,80,0.15); }
        .btn-auth {
            background: linear-gradient(135deg, #2e7d32, #4caf50);
            border: none; border-radius: 8px; padding: 11px; font-weight: 600; color: white; width: 100%;
        }
        .btn-auth:hover { color: white; opacity: 0.95; }
        .input-icon-wrap { position: relative; }
        .input-icon-wrap i { position: absolute; left: 13px; top: 50%; transform: translateY(-50%); color: #bbb; font-size: 0.85rem; z-index: 2; }
        .input-icon-wrap .form-control { padding-left: 36px; }
        .input-icon-wrap.input-password-wrap .form-control { padding-right: 42px; }
        .btn-toggle-sifre {
            position: absolute; right: 4px; top: 50%; transform: translateY(-50%);
            border: none; background: transparent; color: #888; padding: 6px 10px; cursor: pointer; border-radius: 8px;
        }
        .btn-toggle-sifre:hover { color: #2e7d32; background: rgba(46,125,50,0.08); }
    </style>
</head>
<body>
    <div class="auth-card">
        @if (hasToken)
        {
            <h2><i class="fas fa-key text-success me-2"></i>Yeni şifre</h2>
            <p class="subtitle">E-postanızdaki bağlantıyla geldiniz. Yeni şifrenizi belirleyin (en az 6 karakter).</p>
            <div class="alert alert-light border small py-2 mb-3">
                Bağlantı süresi dolduysa veya maildeki linke hiç tıklamadıysanız <a href="/Home/SifreSifirla" class="text-success fw-semibold text-decoration-none">Şifremi unuttum</a> sayfasından aynı e-posta ile yeni istek gönderin.
            </div>
            <div id="msgSifir" class="alert d-none py-2 small" role="alert"></div>
            <form id="formSifir">
                <input type="hidden" id="resetToken" value="@resetToken" />
                <div class="mb-3">
                    <label class="form-label" for="yeniSifre">Yeni şifre</label>
                    <div class="input-icon-wrap input-password-wrap">
                        <i class="fas fa-lock"></i>
                        <input type="password" class="form-control" id="yeniSifre" required minlength="6" autocomplete="new-password" />
                        <button type="button" class="btn-toggle-sifre" aria-label="Şifreyi göster"><i class="fas fa-eye"></i></button>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="yeniSifre2">Yeni şifre (tekrar)</label>
                    <div class="input-icon-wrap input-password-wrap">
                        <i class="fas fa-lock"></i>
                        <input type="password" class="form-control" id="yeniSifre2" required minlength="6" autocomplete="new-password" />
                        <button type="button" class="btn-toggle-sifre" aria-label="Şifreyi göster"><i class="fas fa-eye"></i></button>
                    </div>
                </div>
                <button type="submit" class="btn btn-auth mb-2" id="btnSifirKaydet">Şifreyi kaydet</button>
            </form>
        }
        else
        {
            <h2><i class="fas fa-unlock-alt text-success me-2"></i>Şifremi unuttum</h2>
            <p class="subtitle">Kayıtlı e-posta adresinizi girin; size şifre sıfırlama bağlantısı gönderelim.</p>
            <div class="alert alert-light border small py-2 mb-3">
                <strong>Nasıl ilerler?</strong>
                <ol class="mb-0 ps-3 mt-1 small">
                    <li>E-postanıza <strong>şifre sıfırlama</strong> mesajı gelir.</li>
                    <li>İçindeki bağlantıya tıklayıp bu sitede yeni şifrenizi yazarsınız.</li>
                    <li>Görmezseniz <strong>spam</strong> klasörüne bakın; birkaç dakika sonra aynı adresle tekrar istek gönderebilirsiniz.</li>
                </ol>
            </div>
            <div id="msgIstek" class="alert d-none py-2 small" role="alert"></div>
            <form id="formIstek">
                <div class="mb-3">
                    <label class="form-label" for="eposta">E-posta</label>
                    <div class="input-icon-wrap">
                        <i class="fas fa-envelope"></i>
                        <input type="email" class="form-control" id="eposta" placeholder="ornek@mail.com" required autocomplete="email" />
                    </div>
                </div>
                <button type="submit" class="btn btn-auth mb-2" id="btnIstekGonder">Bağlantı gönder</button>
            </form>
        }
        <div class="text-center mt-3">
            <a href="/Home/Login" class="small text-success fw-semibold text-decoration-none"><i class="fas fa-arrow-left me-1"></i>Girişe dön</a>
        </div>
    </div>

    <script>
        document.querySelectorAll('.btn-toggle-sifre').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var wrap = btn.closest('.input-password-wrap');
                var input = wrap && wrap.querySelector('input');
                var icon = btn.querySelector('i');
                if (!input || !icon) return;
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.replace('fa-eye', 'fa-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.replace('fa-eye-slash', 'fa-eye');
                }
            });
        });

        @if (hasToken)
        {
            <text>
        document.getElementById('formSifir').addEventListener('submit', async function (e) {
            e.preventDefault();
            var el = document.getElementById('msgSifir');
            var a = document.getElementById('yeniSifre').value;
            var b = document.getElementById('yeniSifre2').value;
            if (a !== b) {
                el.className = 'alert alert-warning py-2 small';
                el.textContent = 'Şifreler eşleşmiyor.';
                el.classList.remove('d-none');
                return;
            }
            var btn = document.getElementById('btnSifirKaydet');
            btn.disabled = true;
            try {
                var r = await fetch('/api/Auth/sifre-sifirla', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token: document.getElementById('resetToken').value, yeniSifre: a })
                });
                var d = await r.json();
                el.className = 'alert py-2 small ' + (r.ok ? 'alert-success' : 'alert-danger');
                el.textContent = d.message || (r.ok ? 'Tamam.' : 'İşlem başarısız.');
                el.classList.remove('d-none');
                if (r.ok) {
                    document.getElementById('formSifir').classList.add('d-none');
                    setTimeout(function () { window.location.href = '/Home/Login'; }, 2000);
                } else {
                    btn.disabled = false;
                }
            } catch {
                el.className = 'alert alert-danger py-2 small';
                el.textContent = 'Sunucuya bağlanılamadı.';
                el.classList.remove('d-none');
                btn.disabled = false;
            }
        });
            </text>
        }
        else
        {
            <text>
        document.getElementById('formIstek').addEventListener('submit', async function (e) {
            e.preventDefault();
            var el = document.getElementById('msgIstek');
            var btn = document.getElementById('btnIstekGonder');
            btn.disabled = true;
            try {
                var r = await fetch('/api/Auth/sifremi-unuttum', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: document.getElementById('eposta').value.trim() })
                });
                var d = await r.json();
                el.className = 'alert alert-success py-2 small';
                el.innerHTML = '<strong>' + (d.message || 'İstek alındı.') + '</strong>'
                    + '<ul class="mb-0 mt-2 ps-3 small"><li>Gelen kutusu ve <strong>spam</strong> klasörünü kontrol edin.</li>'
                    + '<li>Mail birkaç dakika gecikebilir.</li>'
                    + '<li>Görmediyseniz aşağıdaki forma aynı e-postayı yazıp tekrar gönderebilirsiniz.</li></ul>';
                el.classList.remove('d-none');
            } catch {
                el.className = 'alert alert-danger py-2 small';
                el.textContent = 'Sunucuya bağlanılamadı.';
                el.classList.remove('d-none');
            }
            btn.disabled = false;
        });
            </text>
        }
    </script>
</body>
</html>
