@{
    Layout = null;
    var basari = ViewBag.Basari as bool? ?? false;
    var baslik = ViewBag.Baslik as string ?? "İşlem";
    var mesaj = ViewBag.Mesaj as string ?? "";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@baslik - Akıllı Tarım</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #1a3c2e 0%, #2d5a42 50%, #4caf50 100%);
            padding: 24px;
        }
        .sonuc-card {
            background: #fff;
            border-radius: 16px;
            padding: 2rem 2.25rem;
            max-width: 440px;
            width: 100%;
            box-shadow: 0 20px 60px rgba(0,0,0,0.25);
        }
        .sonuc-ikon {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin: 0 auto 1rem;
        }
        .sonuc-ikon.ok { background: #e8f5e9; color: #2e7d32; }
        .sonuc-ikon.err { background: #ffebee; color: #c62828; }
    </style>
</head>
<body>
    <div class="sonuc-card text-center">
        <div class="sonuc-ikon @(basari ? "ok" : "err")">
            <i class="fas @(basari ? "fa-check" : "fa-times")"></i>
        </div>
        <h1 class="h4 fw-bold text-dark mb-2">@baslik</h1>
        <p class="text-muted mb-4" style="font-size:0.95rem;">@mesaj</p>
        <a href="/Home/Login" class="btn btn-success w-100 fw-semibold">Giriş sayfasına git</a>
    </div>
</body>
</html>
